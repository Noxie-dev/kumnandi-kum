# Copy to .env and fill with real values before running Docker.

HOST_PORT=3000
DATABASE_URL=
JWT_SECRET=
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_NEON_AUTH_URL=

# Optional. Used only to grant the first owner admin access.
OWNER_OPEN_ID=

# Forge integration. Leave disabled unless the backend service is provisioned.
FORGE_ENABLED=false
FORGE_API_URL=
FORGE_API_KEY=

# Public browser-side maps config. Do not expose private Forge credentials.
VITE_MAPS_API_KEY=
VITE_MAPS_PROXY_URL=
